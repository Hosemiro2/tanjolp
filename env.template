# Copie este arquivo para .env e preencha com seus valores
# cp env.template .env

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=mysql://usuario:senha@localhost:3306/tanjo_db

# ─── JWT Secret ───────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque-por-uma-chave-longa-e-aleatoria

# ─── OpenAI (Agente Danya + Geração de Imagens) ───────────────────────────────
OPENAI_API_KEY=sk-...

# ─── S3 Storage (AWS S3 ou Cloudflare R2) ────────────────────────────────────
S3_BUCKET=tanjo-storage
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=AKIA...
S3_SECRET_ACCESS_KEY=...
# Para Cloudflare R2: https://<account_id>.r2.cloudflarestorage.com
# Deixe vazio para AWS S3 padrão
S3_ENDPOINT=

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Opcional ─────────────────────────────────────────────────────────────────
# Email para receber notificações de novos leads
OWNER_EMAIL=
