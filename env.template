# ─── TANJŌ Studio · Environment Variables ────────────────────────────────────
# Copie pra .env e preencha. Não commite o .env (já está no .gitignore).

# ─── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3002

# URL pública da LP (usada em e-mails, redirects, etc)
PUBLIC_URL=https://studio.tanjoo.com.br

# Postgres — apontar pro container tanjo-postgres:5433 no servidor Nexus
# Database `tanjo_studio` precisa existir (ver SETUP_POSTGRES.md)
DATABASE_URL=postgresql://postgres:SENHA@localhost:5433/tanjo_studio

# Segredo do cookie JWT (gerar com: openssl rand -hex 32)
JWT_SECRET=COLE-AQUI-UM-HEX-DE-64-CHARS

# E-mail do dono pra receber notificações de novos leads
OWNER_EMAIL=comercial@tanjoo.com.br

# ─── LLM — Anthropic Claude (chat da Danya) ─────────────────────────────────
# Gerar em https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
# Modelo (opcional — default: claude-sonnet-4-5)
# Outras opções: claude-opus-4-7 (caro), claude-haiku-4-5-20251001 (mais rápido)
ANTHROPIC_MODEL=claude-sonnet-4-5

# ─── Image Generation — Leonardo AI ─────────────────────────────────────────
# Gerar em https://app.leonardo.ai/settings/api-access (precisa plano API)
LEONARDO_API_KEY=...
# Model ID (opcional — default é Phoenix 1.0, bom pra fotorrealismo de joias)
# Outros: Leonardo Lightning XL, PhotoReal v2. Lista: https://docs.leonardo.ai/docs/models
LEONARDO_MODEL_ID=de7d3faf-762f-48e0-b3b7-9d0ac3a3fcf3

# ─── Email Transacional — Brevo ─────────────────────────────────────────────
# Gerar em https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-...
BREVO_SENDER_EMAIL=no-reply@tanjoo.com.br
BREVO_SENDER_NAME=TANJŌ Studio

# ─── Storage — Cloudflare R2 ────────────────────────────────────────────────
# 1. Criar bucket em https://dash.cloudflare.com → R2 → Create bucket
# 2. Configurar custom domain (ex: images.tanjoo.com.br) via Cloudflare DNS
# 3. Gerar token em "Manage R2 API tokens" com permissão Edit no bucket
R2_ACCOUNT_ID=...                          # da dashboard Cloudflare (canto superior direito)
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET=tanjo-studio
R2_PUBLIC_BASE_URL=https://images.tanjoo.com.br  # domínio custom do bucket

# ─── Painel Admin ────────────────────────────────────────────────────────────
# Senha de acesso pro painel em /admin/login (escolha algo forte)
ADMIN_PASSWORD=trocar-pra-senha-forte
# Segredo da sessão admin (gerar com: openssl rand -hex 32)
ADMIN_SESSION_SECRET=COLE-AQUI-OUTRO-HEX-DE-64-CHARS
